---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategorySlider from './CategorySlider.astro';
import Button from './Button.astro';
import { categoryGradients, categorySlideCount, type Category } from '../data/categorySlides';
import { type Lang, useTranslatedPath, useTranslations } from '../i18n/ui';

interface Props {
	lang: Lang;
	currentPath: string;
	category: Category;
	titleKey: string;
}

const { lang, currentPath, category, titleKey } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const title = t(titleKey);
const gradients = categoryGradients[category];

const slides = Array.from({ length: categorySlideCount }, (_, i) => ({
	title: t(`categories.${category}.slides.${i}.title`),
	text: t(`categories.${category}.slides.${i}.text`),
	gradient: gradients[i],
}));
---

<BaseLayout lang={lang} currentPath={currentPath} title={`${title} | Playa Venao Adventures`}>
	<section class="category-page section">
		<div class="container category-page__inner">
			<h1 class="category-page__heading display-heading">{title}</h1>
			<p class="category-page__intro">{t(`categories.${category}.intro`)}</p>

			<CategorySlider slides={slides} label={title} />

			<div class="category-page__cta">
				<Button href={translatePath('/contact')} variant="primary">
					{t('categories.bookCta')}
				</Button>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.category-page__inner {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.category-page__heading {
		font-size: clamp(2rem, 5vw, 3rem);
		text-align: center;
	}

	.category-page__intro {
		text-align: center;
		max-width: 42rem;
		margin-inline: auto;
		color: var(--color-text-muted);
		font-size: 1.1rem;
		line-height: 1.7;
	}

	.category-page__cta {
		display: flex;
		justify-content: center;
		margin-top: 1rem;
	}
</style>
