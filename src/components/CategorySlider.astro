---
interface Slide {
	title: string;
	text: string;
	gradient: string;
}

interface Props {
	slides: Slide[];
	label: string;
}

const { slides, label } = Astro.props;
const sliderId = `slider-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="category-slider" data-slider={sliderId}>
	<div class="category-slider__viewport" aria-roledescription="carousel" aria-label={label}>
		<div class="category-slider__track">
			{
				slides.map((slide, index) => (
					<article
						class:list={['category-slider__slide', { 'category-slider__slide--active': index === 0 }]}
						data-slide={index}
						style={`background: ${slide.gradient}`}
						aria-hidden={index !== 0 ? 'true' : undefined}
					>
						<div class="category-slider__slide-inner">
							<h2 class="category-slider__title">{slide.title}</h2>
							<p class="category-slider__text">{slide.text}</p>
						</div>
					</article>
				))
			}
		</div>
	</div>

	<button
		type="button"
		class="category-slider__arrow category-slider__arrow--prev icon--directional"
		aria-label="Previous slide"
		data-prev
	>
		‹
	</button>
	<button
		type="button"
		class="category-slider__arrow category-slider__arrow--next icon--directional"
		aria-label="Next slide"
		data-next
	>
		›
	</button>

	<div class="category-slider__dots" role="tablist" aria-label="Slide navigation">
		{
			slides.map((_, index) => (
				<button
					type="button"
					class:list={['category-slider__dot', { 'category-slider__dot--active': index === 0 }]}
					role="tab"
					aria-selected={index === 0 ? 'true' : 'false'}
					aria-label={`Slide ${index + 1}`}
					data-dot={index}
				/>
			))
		}
	</div>
</div>

<script>
	function initSlider(root: HTMLElement) {
		const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
		const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-dot]'));
		const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev]');
		const nextBtn = root.querySelector<HTMLButtonElement>('[data-next]');
		let current = 0;
		let timer: ReturnType<typeof setInterval> | undefined;

		function goTo(index: number) {
			current = (index + slides.length) % slides.length;
			slides.forEach((slide, i) => {
				slide.classList.toggle('category-slider__slide--active', i === current);
				slide.setAttribute('aria-hidden', i === current ? 'false' : 'true');
			});
			dots.forEach((dot, i) => {
				dot.classList.toggle('category-slider__dot--active', i === current);
				dot.setAttribute('aria-selected', i === current ? 'true' : 'false');
			});
		}

		function startAutoplay() {
			if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
			timer = setInterval(() => goTo(current + 1), 6000);
		}

		function stopAutoplay() {
			if (timer) clearInterval(timer);
		}

		prevBtn?.addEventListener('click', () => {
			stopAutoplay();
			goTo(current - 1);
			startAutoplay();
		});

		nextBtn?.addEventListener('click', () => {
			stopAutoplay();
			goTo(current + 1);
			startAutoplay();
		});

		dots.forEach((dot) => {
			dot.addEventListener('click', () => {
				stopAutoplay();
				goTo(Number(dot.dataset.dot));
				startAutoplay();
			});
		});

		root.addEventListener('mouseenter', stopAutoplay);
		root.addEventListener('mouseleave', startAutoplay);

		goTo(0);
		startAutoplay();
	}

	document.querySelectorAll<HTMLElement>('[data-slider]').forEach(initSlider);
</script>

<style>
	.category-slider {
		position: relative;
		width: 100%;
		max-width: 960px;
		margin-inline: auto;
	}

	.category-slider__viewport {
		overflow: hidden;
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-card);
	}

	.category-slider__track {
		position: relative;
		aspect-ratio: 16 / 9;
		min-height: 320px;
	}

	.category-slider__slide {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: flex-end;
		padding: 2rem;
		opacity: 0;
		transition: opacity 0.5s ease;
		pointer-events: none;
	}

	.category-slider__slide--active {
		opacity: 1;
		pointer-events: auto;
	}

	.category-slider__slide-inner {
		max-width: 36rem;
		color: #fff;
		text-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
	}

	.category-slider__title {
		font-size: clamp(1.5rem, 3vw, 2.25rem);
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.category-slider__text {
		font-size: 1rem;
		line-height: 1.6;
		opacity: 0.95;
	}

	.category-slider__arrow {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 44px;
		height: 44px;
		border-radius: 50%;
		border: none;
		background: rgba(255, 255, 255, 0.92);
		color: var(--color-text);
		font-size: 1.75rem;
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
		transition: transform var(--transition), background var(--transition);
		z-index: 2;
	}

	.category-slider__arrow:hover {
		transform: translateY(-50%) scale(1.05);
		background: #fff;
	}

	.category-slider__arrow--prev {
		inset-inline-start: 1rem;
	}

	.category-slider__arrow--next {
		inset-inline-end: 1rem;
	}

	.category-slider__dots {
		display: flex;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 1.25rem;
	}

	.category-slider__dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		border: none;
		padding: 0;
		background: var(--color-border);
		cursor: pointer;
		transition: background var(--transition), transform var(--transition);
	}

	.category-slider__dot--active {
		background: var(--color-orange);
		transform: scale(1.2);
	}

	@media (max-width: 640px) {
		.category-slider__slide {
			padding: 1.25rem;
		}

		.category-slider__arrow {
			width: 36px;
			height: 36px;
			font-size: 1.5rem;
		}
	}
</style>
