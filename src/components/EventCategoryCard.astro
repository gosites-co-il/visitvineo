---
import SideImageCard from './SideImageCard.astro';

interface Props {
	href: string;
	title: string;
	excerpt: string;
	image: string;
	readMore: string;
	reversed?: boolean;
}

const { href, title, excerpt, image, readMore, reversed = false } = Astro.props;
---

<SideImageCard href={href} image={image} reversed={reversed}>
	<h3 class="side-card__title">{title}</h3>
	<p class="side-card__text">{excerpt}</p>
	<span class="event-card__link">
		{readMore} <span class="icon--directional" aria-hidden="true">→</span>
	</span>
</SideImageCard>

<style>
	.event-card__link {
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-dusty-blue);
	}

	.event-card__link .icon--directional {
		display: inline-block;
	}
</style>
