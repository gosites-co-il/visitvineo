---
import { type Lang, getNavLinks, useTranslatedPath, useTranslations } from '../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const navLinks = getNavLinks(lang);
const phone = t('footer.phone');
const phoneHref = `tel:${phone.replace(/[^\d+]/g, '')}`;
const whatsappHref = `https://wa.me/972525578355`;
---

<footer class="footer">
	<div class="container footer__grid">
		<div class="footer__brand">
			<img src="/brand/logo-horizontal.svg" alt="Playa Venao Adventures" width="160" height="72" />
			<p class="footer__tagline">{t('footer.tagline')}</p>
		</div>

		<nav class="footer__nav" aria-label="Footer">
			{navLinks.map(({ label, href }) => (
				<a href={href}>{label}</a>
			))}
		</nav>

		<div class="footer__contact">
			<p class="footer__contact-label">{t('footer.phoneLabel')}</p>
			<a href={phoneHref} class="footer__phone">{phone}</a>
		</div>

		<div class="footer__social">
			<a href="#" aria-label="Instagram" class="footer__social-link">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path>
				</svg>
			</a>
			<a href={whatsappHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="footer__social-link">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
				</svg>
			</a>
		</div>
	</div>
	<p class="footer__copy container">{t('footer.copyright')}</p>
</footer>

<style>
	.footer {
		background: var(--color-bg-warm);
		border-top: 1px solid rgba(0, 0, 0, 0.06);
		padding-block: 3.5rem 2rem;
	}

	.footer__grid {
		display: grid;
		grid-template-columns: 1.2fr 1.5fr 1fr auto;
		gap: 2rem;
		align-items: start;
		margin-bottom: 2.5rem;
	}

	.footer__tagline {
		margin-top: 0.75rem;
		font-size: 0.9rem;
		color: var(--color-text-muted);
		max-width: 22ch;
	}

	.footer__nav {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.footer__nav a {
		font-weight: 500;
		font-size: 0.95rem;
		opacity: 0.75;
		transition: opacity var(--transition), color var(--transition);
	}

	.footer__nav a:hover {
		opacity: 1;
		color: var(--color-orange);
	}

	.footer__contact-label {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		opacity: 0.5;
		margin-bottom: 0.35rem;
	}

	.footer__phone {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--color-orange);
	}

	.footer__social {
		display: flex;
		gap: 0.75rem;
	}

	.footer__social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 50%;
		border: 1px solid rgba(0, 0, 0, 0.1);
		opacity: 0.7;
		transition: opacity var(--transition), border-color var(--transition), color var(--transition);
	}

	.footer__social-link:hover {
		opacity: 1;
		border-color: var(--color-orange);
		color: var(--color-orange);
	}

	.footer__copy {
		text-align: center;
		font-size: 0.8rem;
		opacity: 0.45;
	}

	@media (max-width: 768px) {
		.footer__grid {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.footer__tagline {
			margin-inline: auto;
		}

		.footer__nav {
			align-items: center;
		}

		.footer__social {
			justify-content: center;
		}
	}
</style>
