---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { type Lang, getNavLinks, useTranslatedPath, useTranslations } from '../i18n/ui';

interface Props {
	lang: Lang;
	currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const navLinks = getNavLinks(lang);
---

<header class="header" id="site-header">
	<div class="header__inner container">
		<a href={translatePath('/')} class="header__logo" aria-label="Playa Venao Adventures">
			<img src="/brand/logo-badge.svg" alt="" width="48" height="48" />
			<span class="header__logo-text">
				<span class="header__logo-name">Playa Venao</span>
				<span class="header__logo-sub">Adventures</span>
			</span>
		</a>

		<nav class="header__nav" aria-label="Main">
			{navLinks.map(({ label, href }) => (
				<a href={href}>{label}</a>
			))}
		</nav>

		<div class="header__actions">
			<LanguageSwitcher lang={lang} currentPath={currentPath} />
			<a href={translatePath('/contact')} class="btn btn--primary header__book">
				{t('nav.bookNow')}
			</a>
			<button class="header__menu-btn" aria-label="Open menu" aria-expanded="false" id="menu-toggle">
				<span></span><span></span><span></span>
			</button>
		</div>
	</div>

	<div class="header__mobile-nav" id="mobile-nav" hidden>
		{navLinks.map(({ label, href }) => (
			<a href={href}>{label}</a>
		))}
		<a href={translatePath('/contact')} class="btn btn--primary">{t('nav.bookNow')}</a>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const toggle = document.getElementById('menu-toggle');
	const mobileNav = document.getElementById('mobile-nav');

	window.addEventListener('scroll', () => {
		header?.classList.toggle('header--scrolled', window.scrollY > 20);
	});

	toggle?.addEventListener('click', () => {
		const open = mobileNav?.hasAttribute('hidden');
		if (open) {
			mobileNav?.removeAttribute('hidden');
			toggle?.setAttribute('aria-expanded', 'true');
		} else {
			mobileNav?.setAttribute('hidden', '');
			toggle?.setAttribute('aria-expanded', 'false');
		}
	});

	mobileNav?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			mobileNav?.setAttribute('hidden', '');
			toggle?.setAttribute('aria-expanded', 'false');
		});
	});
</script>

<style>
	.header {
		position: fixed;
		inset-inline: 0;
		top: 0;
		z-index: 100;
		height: var(--header-height);
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid transparent;
		transition: box-shadow var(--transition), border-color var(--transition);
	}

	.header--scrolled {
		border-bottom: 1px solid rgba(0, 0, 0, 0.06);
		box-shadow: var(--shadow-soft);
	}

	.header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 100%;
		gap: 1rem;
	}

	.header__logo {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-shrink: 0;
	}

	.header__logo-text {
		display: flex;
		flex-direction: column;
		line-height: 1.1;
	}

	.header__logo-name {
		font-family: var(--font-display);
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--color-orange);
	}

	.header__logo-sub {
		font-size: 0.6rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		opacity: 0.7;
	}

	.header__nav {
		display: flex;
		gap: clamp(0.5rem, 1.5vw, 1.25rem);
	}

	.header__nav a {
		font-size: 0.875rem;
		font-weight: 500;
		opacity: 0.8;
		transition: opacity var(--transition), color var(--transition);
		white-space: nowrap;
	}

	.header__nav a:hover {
		opacity: 1;
		color: var(--color-orange);
	}

	.header__actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.header__book {
		padding: 0.55rem 1.1rem;
		font-size: 0.8rem;
		white-space: nowrap;
	}

	.header__menu-btn {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
	}

	.header__menu-btn span {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--color-text);
		border-radius: 2px;
	}

	.header__mobile-nav {
		display: none;
		flex-direction: column;
		gap: 1rem;
		padding: 1.25rem 1.25rem 1.75rem;
		background: var(--color-bg);
		border-bottom: 1px solid rgba(0, 0, 0, 0.06);
	}

	.header__mobile-nav a {
		font-size: 1.05rem;
		font-weight: 600;
	}

	@media (max-width: 1024px) {
		.header__nav,
		.header__book {
			display: none;
		}

		.header__menu-btn {
			display: flex;
		}

		.header__mobile-nav:not([hidden]) {
			display: flex;
		}
	}

	@media (max-width: 480px) {
		.header__logo-text {
			display: none;
		}
	}
</style>
