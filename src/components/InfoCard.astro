---
import BrandIcon from './BrandIcon.astro';

interface Props {
	title: string;
	body: string;
	icon?: string;
	brandIcon?: 'waves' | 'sun' | 'palm' | 'birds' | 'fishing';
	iconAccent?: 'sage' | 'orange' | 'blue' | 'lavender';
	image?: string;
}

const { title, body, icon, brandIcon, iconAccent = 'blue', image } = Astro.props;
---

<article class="info-card card">
	{image && (
		<div class="info-card__image">
			<img src={image} alt="" loading="lazy" />
		</div>
	)}
	<div class="info-card__body">
		{brandIcon ? (
			<span class:list={['info-card__icon', `info-card__icon--${iconAccent}`]} aria-hidden="true">
				<BrandIcon name={brandIcon} accent={iconAccent} size={36} />
			</span>
		) : icon ? (
			<span class="info-card__icon info-card__icon--emoji" aria-hidden="true">{icon}</span>
		) : null}
		<h3 class="info-card__title">{title}</h3>
		<p class="info-card__text">{body}</p>
	</div>
</article>

<style>
	.info-card__image {
		aspect-ratio: 16 / 10;
		overflow: hidden;
	}

	.info-card__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.info-card:hover .info-card__image img {
		transform: scale(1.04);
	}

	.info-card__body {
		padding: 1.75rem;
	}

	.info-card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 64px;
		height: 64px;
		border-radius: 50%;
		margin-bottom: 1rem;
	}

	.info-card__icon--sage {
		background: rgba(134, 184, 119, 0.14);
		border: 1px solid rgba(134, 184, 119, 0.35);
	}

	.info-card__icon--orange {
		background: rgba(248, 183, 91, 0.14);
		border: 1px solid rgba(248, 183, 91, 0.4);
	}

	.info-card__icon--blue {
		background: rgba(142, 206, 205, 0.16);
		border: 1px solid rgba(142, 206, 205, 0.4);
	}

	.info-card__icon--lavender {
		background: rgba(226, 163, 198, 0.14);
		border: 1px solid rgba(226, 163, 198, 0.35);
	}

	.info-card__icon--emoji {
		font-size: 1.4rem;
		background: rgba(248, 183, 91, 0.14);
		width: 48px;
		height: 48px;
	}

	.info-card__title {
		font-size: 1.2rem;
		font-weight: 700;
		margin-bottom: 0.6rem;
		color: var(--color-text);
	}

	.info-card__text {
		font-size: 0.98rem;
		color: var(--color-text-muted);
		line-height: 1.75;
	}
</style>
