---
import { type Lang, useTranslatedPath } from '../i18n/ui';

interface Props {
	lang: Lang;
	currentPath: string;
}

const { lang, currentPath } = Astro.props;
const translatePath = useTranslatedPath(lang);
---

<div class="lang-switcher" role="navigation" aria-label="Language">
	<a
		href={translatePath(currentPath, 'he')}
		class:list={['lang-switcher__link', { 'lang-switcher__link--active': lang === 'he' }]}
		aria-current={lang === 'he' ? 'page' : undefined}
	>
		עב
	</a>
	<span class="lang-switcher__sep" aria-hidden="true">|</span>
	<a
		href={translatePath(currentPath, 'en')}
		class:list={['lang-switcher__link', { 'lang-switcher__link--active': lang === 'en' }]}
		aria-current={lang === 'en' ? 'page' : undefined}
	>
		EN
	</a>
</div>

<style>
	.lang-switcher {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.875rem;
		font-weight: 600;
	}

	.lang-switcher__sep {
		opacity: 0.4;
	}

	.lang-switcher__link {
		opacity: 0.55;
		transition: opacity var(--transition);
		padding: 0.25rem 0.35rem;
	}

	.lang-switcher__link:hover,
	.lang-switcher__link--active {
		opacity: 1;
		color: var(--color-orange);
	}
</style>
