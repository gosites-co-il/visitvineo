---
interface Props {
	title: string;
	subtitle?: string;
	image: string;
	cta?: { label: string; href: string };
	overlay?: boolean;
	fullHeight?: boolean;
}

const { title, subtitle, image, cta, overlay = true, fullHeight = true } = Astro.props;
---

<section class:list={['page-hero', { 'page-hero--full': fullHeight }]}>
	<img src={image} alt="" class="page-hero__bg" loading="eager" />
	{overlay && <div class="page-hero__overlay"></div>}
	<div class="container page-hero__content fade-up">
		<h1 class="page-hero__title">{title}</h1>
		{subtitle && <p class="page-hero__subtitle">{subtitle}</p>}
		{cta && (
			<a href={cta.href} class="btn btn--primary page-hero__cta">
				{cta.label}
			</a>
		)}
	</div>
</section>

<style>
	.page-hero {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		min-height: 360px;
		margin-top: calc(-1 * var(--header-height));
		padding-top: var(--header-height);
	}

	.page-hero--full {
		min-height: max(520px, 85vh);
	}

	.page-hero__bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.page-hero__overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to top,
			rgba(0, 0, 0, 0.55) 0%,
			rgba(0, 0, 0, 0.25) 50%,
			rgba(0, 0, 0, 0.15) 100%
		);
	}

	.page-hero__content {
		position: relative;
		z-index: 1;
		text-align: center;
		color: #fff;
		padding-block: 3rem;
	}

	.page-hero__title {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 700;
		max-width: 18ch;
		margin-inline: auto;
		margin-bottom: 1rem;
		text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
	}

	.page-hero__subtitle {
		font-size: clamp(1rem, 2.5vw, 1.2rem);
		max-width: 46ch;
		margin-inline: auto;
		margin-bottom: 2rem;
		opacity: 0.92;
		line-height: 1.7;
	}

	.page-hero__cta {
		margin-top: 0.5rem;
	}
</style>
