---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
	lang: Lang;
	currentPath: string;
	titleKey: string;
}

const { lang, currentPath, titleKey } = Astro.props;
const t = useTranslations(lang);
const title = t(titleKey);
---

<BaseLayout lang={lang} currentPath={currentPath} title={`${title} | Playa Venao Adventures`}>
	<section class="placeholder section">
		<div class="container">
			<h1 class="display-heading">{title}</h1>
			<p>{t('pages.comingSoon')}</p>
		</div>
	</section>
</BaseLayout>

<style>
	.placeholder {
		min-height: 50vh;
		display: flex;
		align-items: center;
		text-align: center;
	}

	.placeholder h1 {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}
</style>
