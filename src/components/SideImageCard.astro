---
interface Props {
	image: string;
	reversed?: boolean;
	href?: string;
}

const { image, reversed = false, href } = Astro.props;
const Tag = href ? 'a' : 'article';
---

<Tag
	href={href}
	class:list={['side-card', 'card', { 'side-card--reversed': reversed, 'side-card--link': href }]}
>
	<div class="side-card__image">
		<img src={image} alt="" loading="lazy" />
	</div>
	<div class="side-card__body">
		<slot />
	</div>
</Tag>

<style>
	.side-card {
		display: flex;
		flex-direction: row;
		align-items: stretch;
		color: inherit;
		width: 100%;
	}

	.side-card--link {
		text-decoration: none;
	}

	.side-card--reversed {
		flex-direction: row-reverse;
	}

	.side-card__image {
		flex-shrink: 0;
		width: 120px;
		overflow: hidden;
	}

	.side-card__image img {
		width: 100%;
		height: 100%;
		min-height: 96px;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.side-card:hover .side-card__image img {
		transform: scale(1.05);
	}

	.side-card__body {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 0.85rem 1rem;
		min-width: 0;
	}

	:global(.side-card__title) {
		font-size: 0.98rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		color: var(--color-orange);
		line-height: 1.3;
	}

	:global(.side-card__label) {
		font-size: 0.78rem;
		font-weight: 700;
		margin-bottom: 0.2rem;
		color: var(--color-text);
	}

	:global(.side-card__text) {
		font-size: 0.84rem;
		color: var(--color-text-muted);
		line-height: 1.55;
		margin-bottom: 0.65rem;
	}

	:global(.side-card__text:last-child) {
		margin-bottom: 0;
	}

	:global(.side-card__includes) {
		color: var(--color-text);
		font-weight: 500;
	}

	@media (min-width: 640px) {
		.side-card__image {
			width: 160px;
		}

		.side-card__body {
			padding: 1.1rem 1.35rem;
		}

		:global(.side-card__title) {
			font-size: 1.05rem;
		}
	}
</style>
