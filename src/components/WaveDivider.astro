---
interface Props {
	variant?: 'sage' | 'blue' | 'orange';
	flip?: boolean;
}

const { variant = 'blue', flip = false } = Astro.props;

const colors = {
	sage: '#8fa68a',
	blue: '#5b8fa8',
	orange: '#e8a84c',
};
---

<div class:list={['wave-divider', { 'wave-divider--flip': flip }]} aria-hidden="true">
	<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
		<path
			d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"
			fill={colors[variant]}></path>
		<path
			d="M0,50 Q360,20 720,50 T1440,50"
			fill="none"
			stroke={colors[variant]}
			stroke-width="3"
			opacity="0.5"></path>
	</svg>
</div>

<style>
	.wave-divider {
		line-height: 0;
		margin-block: -1px;
	}

	.wave-divider svg {
		width: 100%;
		height: 60px;
		display: block;
	}

	.wave-divider--flip {
		transform: scaleY(-1);
	}
</style>
