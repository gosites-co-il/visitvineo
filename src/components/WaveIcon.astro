---
interface Props {
	accent?: 'sage' | 'orange' | 'blue' | 'lavender';
	size?: number;
}

const { accent = 'blue', size = 40 } = Astro.props;

const colors = {
	sage: '#8fa68a',
	orange: '#d4923a',
	blue: '#5b8fa8',
	lavender: '#c4b5c9',
};
---

<svg
	class="wave-icon"
	width={size}
	height={size * 0.5}
	viewBox="0 0 80 40"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	aria-hidden="true"
>
	<path
		d="M4 28 C16 20, 24 20, 32 28 S48 36, 56 28 S72 20, 76 28"
		stroke={colors[accent]}
		stroke-width="2.5"
		stroke-linecap="round"
		fill="none"></path>
	<path
		d="M4 22 C16 14, 24 14, 32 22 S48 30, 56 22 S72 14, 76 22"
		stroke={colors[accent]}
		stroke-width="2.5"
		stroke-linecap="round"
		fill="none"
		opacity="0.75"></path>
	<path
		d="M4 16 C16 8, 24 8, 32 16 S48 24, 56 16 S72 8, 76 16"
		stroke={colors[accent]}
		stroke-width="2.5"
		stroke-linecap="round"
		fill="none"
		opacity="0.5"></path>
</svg>

<style>
	.wave-icon {
		display: block;
	}
</style>
