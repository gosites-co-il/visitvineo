---
import Button from '../Button.astro';
import WaveDivider from '../WaveDivider.astro';
import { type Lang, useTranslatedPath, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<WaveDivider variant="sage" />
<section class="book-cta section">
	<div class="container book-cta__inner">
		<h2 class="book-cta__title display-heading">{t('home.cta.title')}</h2>
		<p class="book-cta__subtitle">{t('home.cta.subtitle')}</p>
		<Button href={translatePath('/contact')} variant="white">{t('home.cta.button')}</Button>
	</div>
</section>

<style>
	.book-cta {
		background: linear-gradient(135deg, var(--color-orange) 0%, #c8872e 100%);
		color: var(--color-black);
	}

	.book-cta__inner {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.book-cta__title {
		font-size: clamp(1.75rem, 4vw, 2.75rem);
	}

	.book-cta__subtitle {
		font-size: 1.05rem;
		max-width: 40ch;
		opacity: 0.85;
		margin-bottom: 0.5rem;
	}
</style>
