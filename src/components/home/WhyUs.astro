---
import WaveDivider from '../WaveDivider.astro';
import { type Lang, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
	{ key: 'local', icon: '🌴', color: 'orange' },
	{ key: 'levels', icon: '🏄', color: 'blue' },
	{ key: 'groups', icon: '✨', color: 'sage' },
] as const;
---

<WaveDivider variant="blue" flip />
<section class="why section">
	<div class="container">
		<h2 class="section-heading why__title">{t('home.whyUs.title')}</h2>
		<div class="why__grid">
			{
				items.map(({ key, icon, color }) => (
					<div class="why__item">
						<div class:list={['why__icon', `why__icon--${color}`]} aria-hidden="true">
							{icon}
						</div>
						<h3 class="why__item-title">{t(`home.whyUs.${key}.title`)}</h3>
						<p class="why__item-body">{t(`home.whyUs.${key}.body`)}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.why {
		background: var(--color-bg);
	}

	.why__title {
		margin-bottom: 3rem;
	}

	.why__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.why__item {
		text-align: center;
		padding: 1.5rem;
	}

	.why__icon {
		width: 64px;
		height: 64px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.75rem;
		margin-inline: auto;
		margin-bottom: 1.25rem;
	}

	.why__icon--orange {
		background: rgba(232, 168, 76, 0.15);
		border: 2px solid var(--color-orange);
	}

	.why__icon--blue {
		background: rgba(91, 143, 168, 0.15);
		border: 2px solid var(--color-dusty-blue);
	}

	.why__icon--sage {
		background: rgba(143, 166, 138, 0.15);
		border: 2px solid var(--color-sage);
	}

	.why__item-title {
		font-size: 1.15rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.why__item-body {
		font-size: 0.95rem;
		opacity: 0.75;
		max-width: 28ch;
		margin-inline: auto;
	}

	@media (max-width: 767px) {
		.why__grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}
</style>
