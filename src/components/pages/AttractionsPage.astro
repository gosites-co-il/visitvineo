---
import PageHero from '../PageHero.astro';
import EventCategoryCard from '../EventCategoryCard.astro';
import { attractionActivities } from '../../data/attractions';
import { type Lang, useTranslatedPath, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<PageHero
	title={t('attractions.title')}
	image="https://images.unsplash.com/photo-1502680390468-be998c1370d7?w=1920&q=80"
	fullHeight={false}
	overlay={true}
/>

<section class="section">
	<div class="container attractions-intro">
		<p class="attractions-intro__text">{t('attractions.intro')}</p>
	</div>
</section>

<section class="section section--warm">
	<div class="container">
		<h2 class="section-heading">{t('attractions.flagshipTitle')}</h2>

		<div class="attractions-list">
			{attractionActivities.map(({ id, slug, image }) => (
				<EventCategoryCard
					href={translatePath(`/attractions/${slug}`)}
					title={t(`attractions.activities.${id}.title`)}
					excerpt={t(`attractions.activities.${id}.short`)}
					image={image}
					readMore={t('attractions.readMore')}
				/>
			))}
		</div>

		<div class="attractions-cta">
			<a href={translatePath('/contact')} class="btn btn--primary">{t('packagesPage.cta')}</a>
		</div>
	</div>
</section>

<style>
	.attractions-intro {
		max-width: 44rem;
		margin-inline: auto;
		text-align: center;
	}

	.attractions-intro__text {
		font-size: 1.15rem;
		line-height: 1.9;
		color: var(--color-text-muted);
	}

	.attractions-list {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
		margin-top: 2rem;
		align-items: stretch;
	}

	.attractions-list :global(.side-card) {
		height: 100%;
	}

	@media (max-width: 639px) {
		.attractions-list {
			grid-template-columns: 1fr;
		}
	}

	.attractions-cta {
		text-align: center;
		margin-top: 2.5rem;
	}
</style>
