---
import PageHero from '../PageHero.astro';
import { type Lang, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const restaurants = [
	{ id: 'yasu', image: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&q=80' },
	{ id: 'sol', image: 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=800&q=80' },
	{ id: 'coleos', image: 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=800&q=80' },
	{ id: 'michaela', image: 'https://images.unsplash.com/photo-1559339352-11d035aa65de?w=800&q=80' },
] as const;
---

<PageHero
	title={t('culinary.title')}
	subtitle={t('culinary.intro')}
	image="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1920&q=80"
	fullHeight={false}
/>

<section class="section">
	<div class="container">
		<div class="restaurants">
			{restaurants.map(({ id, image }) => (
				<article class="restaurant card">
					<div class="restaurant__image">
						<img src={image} alt="" loading="lazy" />
					</div>
					<div class="restaurant__body">
						<h3 class="restaurant__name">{t(`culinary.restaurants.${id}.name`)}</h3>
						<p class="restaurant__desc">{t(`culinary.restaurants.${id}.description`)}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.restaurants {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.restaurant__image {
		aspect-ratio: 4 / 3;
		overflow: hidden;
	}

	.restaurant__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.restaurant:hover .restaurant__image img {
		transform: scale(1.05);
	}

	.restaurant__body {
		padding: 1.5rem;
	}

	.restaurant__name {
		font-size: 1.15rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		color: var(--color-orange);
	}

	.restaurant__desc {
		font-size: 0.95rem;
		color: var(--color-text-muted);
		line-height: 1.7;
	}
</style>
