---
import PageHero from '../PageHero.astro';
import { type EventDetailId, eventDetailIncludes } from '../../data/events';
import { type Lang, useTranslatedPath, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Lang;
	eventId: EventDetailId;
	heroImage: string;
}

const { lang, eventId, heroImage } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const includeKeys = eventDetailIncludes[eventId];
const eventsPath = translatePath('/events');
---

<PageHero
	title={t(`eventsDetail.${eventId}.title`)}
	subtitle={t(`eventsDetail.${eventId}.intro`)}
	image={heroImage}
	fullHeight={false}
/>

<section class="section">
	<div class="container event-detail">
		<p class="event-detail__body">{t(`eventsDetail.${eventId}.body`)}</p>

		<h2 class="event-detail__includes-title">{t('eventsPage.includesTitle')}</h2>
		<ul class="event-detail__list">
			{includeKeys.map((key) => (
				<li>{t(`eventsDetail.${eventId}.includes.${key}`)}</li>
			))}
		</ul>

		<div class="event-detail__actions">
			<a href={translatePath('/contact')} class="btn btn--primary">{t('eventsPage.cta')}</a>
			<a href={eventsPath} class="btn btn--secondary">{t('eventsPage.backToEvents')}</a>
		</div>
	</div>
</section>

<style>
	.event-detail {
		max-width: 44rem;
	}

	.event-detail__body {
		font-size: 1.1rem;
		line-height: 1.9;
		color: var(--color-text-muted);
		margin-bottom: 2.5rem;
	}

	.event-detail__includes-title {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		margin-bottom: 1.25rem;
		color: var(--color-orange);
	}

	.event-detail__list {
		list-style: disc;
		padding-inline-start: 1.5rem;
		margin-bottom: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.event-detail__list li {
		color: var(--color-text-muted);
		line-height: 1.75;
	}

	.event-detail__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}
</style>
