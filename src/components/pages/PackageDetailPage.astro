---
import BookingOrderForm from '../BookingOrderForm.astro';
import PageHero from '../PageHero.astro';
import WhyBookBlock from '../WhyBookBlock.astro';
import EventCategoryCard from '../EventCategoryCard.astro';
import { type PackageId, packageIncludes, vacationPackages } from '../../data/packages';
import { type Lang, useTranslatedPath, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Lang;
	packageId: PackageId;
	heroImage: string;
}

const { lang, packageId, heroImage } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const packagesPath = translatePath('/packages');
const activityKey = `packagesPage.activities.${packageId}`;
const storyParagraphs = t(`${activityKey}.story`).split('\n\n').filter(Boolean);
const includeKeys = packageIncludes[packageId];
const otherPackages = vacationPackages.filter((pkg) => pkg.id !== packageId);
---

<PageHero
	title={t(`${activityKey}.title`)}
	subtitle={t(`${activityKey}.short`)}
	image={heroImage}
	fullHeight={false}
/>

<section class="section">
	<div class="container package-detail">
		<div class="package-detail__main">
			<div class="package-detail__content">
				<h2 class="package-detail__heading">{t('packagesPage.storyLabel')}</h2>
				<div class="package-detail__story">
					{storyParagraphs.map((paragraph) => (
						<p class="package-detail__body">{paragraph}</p>
					))}
				</div>
			</div>

			<aside class="package-detail__form">
				<h2 class="package-detail__heading">{t('packagesPage.orderFormTitle')}</h2>
				<p class="package-detail__form-intro">{t('packagesPage.orderFormIntro')}</p>
				<BookingOrderForm
					lang={lang}
					formId={`package-booking-${packageId}`}
					activityTitle={t(`${activityKey}.title`)}
				/>
			</aside>

			<div class="package-detail__includes">
				<h2 class="package-detail__heading">{t('packagesPage.includesLabel')}</h2>
				<ul class="package-detail__list">
					{includeKeys.map((key) => (
						<li>{t(`${activityKey}.includes.${key}`)}</li>
					))}
				</ul>
			</div>
		</div>
	</div>
</section>

<section class="section section--sand">
	<div class="container">
		<h2 class="section-heading">{t('packagesPage.otherPackagesTitle')}</h2>
		<div class="package-detail__others">
			{otherPackages.map(({ id, slug, image }) => (
				<EventCategoryCard
					href={translatePath(`/packages/${slug}`)}
					title={t(`packagesPage.activities.${id}.title`)}
					excerpt={t(`packagesPage.activities.${id}.short`)}
					image={image}
					readMore={t('packagesPage.readMore')}
				/>
			))}
		</div>
	</div>
</section>

<WhyBookBlock lang={lang} scope="packages" />

<section class="section">
	<div class="container package-detail__actions-wrap">
		<div class="package-detail__actions">
			<a href={packagesPath} class="btn btn--secondary">{t('packagesPage.backToPackages')}</a>
		</div>
	</div>
</section>

<style>
	.package-detail {
		max-width: 56rem;
		margin-inline: auto;
	}

	.package-detail__main {
		display: grid;
		grid-template-columns: 1fr minmax(280px, 340px);
		grid-template-rows: auto auto;
		gap: 2rem 2.5rem;
		align-items: start;
	}

	.package-detail__content {
		grid-column: 1;
		grid-row: 1;
	}

	.package-detail__includes {
		grid-column: 1;
		grid-row: 2;
	}

	.package-detail__form {
		grid-column: 2;
		grid-row: 1 / -1;
		position: sticky;
		top: calc(var(--header-height, 72px) + 1.25rem);
		align-self: start;
	}

	.package-detail__heading {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: var(--color-orange);
	}

	.package-detail__story {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.package-detail__body {
		font-size: 1.1rem;
		line-height: 1.9;
		color: var(--color-text-muted);
		margin: 0;
	}

	.package-detail__list {
		list-style: disc;
		padding-inline-start: 1.5rem;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.package-detail__list li {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--color-text);
	}

	.package-detail__form-intro {
		font-size: 1rem;
		line-height: 1.75;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
	}

	.package-detail__others {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
		margin-top: 2rem;
		align-items: stretch;
	}

	.package-detail__others :global(.side-card) {
		height: 100%;
		flex-direction: column;
	}

	.package-detail__others :global(.side-card__image) {
		width: 100%;
		aspect-ratio: 4 / 3;
	}

	.package-detail__others :global(.side-card__image img) {
		min-height: 0;
		height: 100%;
	}

	.package-detail__others :global(.side-card--reversed) {
		flex-direction: column;
	}

	.package-detail__others :global(.side-card__body) {
		padding: 0.85rem 1rem;
	}

	.package-detail__others :global(.side-card__title) {
		font-size: 0.82rem;
	}

	.package-detail__others :global(.side-card__text) {
		font-size: 0.78rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 1100px) {
		.package-detail__others {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 700px) {
		.package-detail__others {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 420px) {
		.package-detail__others {
			grid-template-columns: 1fr;
		}

		.package-detail__others :global(.side-card) {
			flex-direction: row;
		}

		.package-detail__others :global(.side-card__image) {
			width: 120px;
			aspect-ratio: auto;
		}
	}

	.package-detail__actions-wrap {
		max-width: 44rem;
		margin-inline: auto;
	}

	.package-detail__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
	}

	@media (max-width: 900px) {
		.package-detail__main {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
		}

		.package-detail__content,
		.package-detail__includes,
		.package-detail__form {
			grid-column: 1;
			grid-row: auto;
		}

		.package-detail__form {
			position: static;
		}
	}
</style>
