---
import PageHero from '../PageHero.astro';
import WhyBookBlock from '../WhyBookBlock.astro';
import { surfProducts } from '../../data/surf';
import { type Lang, useTranslatedPath, useTranslations } from '../../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<PageHero
	badge={t('surfPage.heroBadge')}
	title={t('surfPage.title')}
	image="https://images.unsplash.com/photo-1505142468610-359e7d316be0?w=1920&q=80"
	fullHeight={false}
/>

<section class="section">
	<div class="container surf-intro">
		<p class="surf-intro__text">{t('surfPage.intro')}</p>
		<p class="surf-intro__text">{t('surfPage.intro2')}</p>
		<blockquote class="surf-intro__quote">{t('surfPage.quote')}</blockquote>
	</div>
</section>

<section class="section section--warm">
	<div class="container">
		<h2 class="section-heading">{t('surfPage.productsTitle')}</h2>
		<div class="surf-products">
			{surfProducts.map(({ id, slug, image }) => (
				<a href={translatePath(`/surf/${slug}`)} class="surf-product card surf-product--link">
					<div class="surf-product__image">
						<img src={image} alt="" loading="lazy" />
					</div>
					<div class="surf-product__body">
						<h3 class="surf-product__title">{t(`surfPage.products.${id}.title`)}</h3>
						<p class="surf-product__excerpt">{t(`surfPage.products.${id}.subtitle`)}</p>
						<span class="surf-product__more">
							{t('surfPage.readMore')} <span class="icon--directional" aria-hidden="true">→</span>
						</span>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<WhyBookBlock lang={lang} scope="surf" />

<section class="section surf-cta">
	<div class="container surf-cta__inner">
		<a href={translatePath('/contact')} class="btn btn--primary">{t('surfPage.cta')}</a>
	</div>
</section>

<style>
	.surf-intro {
		max-width: 44rem;
		margin-inline: auto;
	}

	.surf-intro__text {
		font-size: 1.1rem;
		line-height: 1.9;
		color: var(--color-text-muted);
		margin-bottom: 1.25rem;
	}

	.surf-intro__quote {
		margin: 2rem 0 0;
		padding: 1.25rem 1.5rem;
		border-inline-start: 4px solid var(--color-orange);
		background: var(--color-warm-bg, #f8f4ef);
		font-size: 1.05rem;
		font-weight: 600;
		font-style: normal;
		line-height: 1.7;
		color: var(--color-text);
	}

	.surf-products {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
		margin-top: 2rem;
		align-items: stretch;
	}

	.surf-product {
		display: flex;
		flex-direction: column;
		overflow: hidden;
		height: 100%;
		color: inherit;
		text-decoration: none;
		transition: box-shadow 0.2s ease, transform 0.2s ease;
	}

	.surf-product--link:hover {
		box-shadow: var(--shadow-card-hover, 0 8px 24px rgba(0, 0, 0, 0.08));
		transform: translateY(-2px);
	}

	.surf-product--link:hover .surf-product__image img {
		transform: scale(1.04);
	}

	.surf-product__image {
		aspect-ratio: 4 / 3;
		flex-shrink: 0;
		overflow: hidden;
		line-height: 0;
		background: var(--color-warm-bg, #f0ebe4);
	}

	.surf-product__image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		transition: transform 0.5s ease;
	}

	.surf-product__body {
		flex: 1;
		display: flex;
		flex-direction: column;
		padding: 1.25rem 1.35rem 1.5rem;
	}

	.surf-product__title {
		font-family: var(--font-display);
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-orange);
		margin-bottom: 0.4rem;
		line-height: 1.35;
	}

	.surf-product__excerpt {
		flex: 1;
		font-size: 0.88rem;
		line-height: 1.65;
		color: var(--color-text-muted);
		margin-bottom: 0.75rem;
	}

	.surf-product__more {
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-dusty-blue);
	}

	.surf-product__more .icon--directional {
		display: inline-block;
	}

	.surf-cta__inner {
		text-align: center;
	}

	@media (max-width: 639px) {
		.surf-products {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.surf-product__body {
			padding: 1.5rem;
		}

		.surf-product__title {
			font-size: 1.15rem;
		}

		.surf-product__excerpt {
			font-size: 1rem;
		}
	}
</style>
