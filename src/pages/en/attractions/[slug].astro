---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AttractionDetailPage from '../../../components/pages/AttractionDetailPage.astro';
import { allAttractionSlugs, getAttractionBySlug } from '../../../data/attractions';
import { useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
	return allAttractionSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const attraction = getAttractionBySlug(slug!);

if (!attraction) {
	return Astro.redirect('/en/attractions');
}

const t = useTranslations('en');
const currentPath = `/attractions/${slug}`;
---

<BaseLayout
	lang="en"
	currentPath={currentPath}
	title={`${t(`attractions.activities.${attraction.id}.title`)} | Playa Venao Adventures`}
>
	<AttractionDetailPage lang="en" attractionId={attraction.id} heroImage={attraction.image} />
</BaseLayout>
