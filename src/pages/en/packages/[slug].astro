---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PackageDetailPage from '../../../components/pages/PackageDetailPage.astro';
import { allPackageSlugs, getPackageBySlug } from '../../../data/packages';
import { useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
	return allPackageSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const pkg = getPackageBySlug(slug!);

if (!pkg) {
	return Astro.redirect('/en/packages');
}

const t = useTranslations('en');
const currentPath = `/packages/${slug}`;
---

<BaseLayout
	lang="en"
	currentPath={currentPath}
	title={`${t(`packagesPage.activities.${pkg.id}.title`)} | Playa Venao Adventures`}
>
	<PackageDetailPage lang="en" packageId={pkg.id} heroImage={pkg.image} />
</BaseLayout>
