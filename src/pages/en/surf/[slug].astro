---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SurfProductDetailPage from '../../../components/pages/SurfProductDetailPage.astro';
import { allSurfProductSlugs, getSurfProductBySlug } from '../../../data/surf';
import { useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
	return allSurfProductSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const product = getSurfProductBySlug(slug!);

if (!product) {
	return Astro.redirect('/en/surf');
}

const t = useTranslations('en');
const currentPath = `/surf/${slug}`;
---

<BaseLayout
	lang="en"
	currentPath={currentPath}
	title={`${t(`surfPage.products.${product.id}.title`)} | Playa Venao Adventures`}
>
	<SurfProductDetailPage lang="en" productId={product.id} heroImage={product.image} />
</BaseLayout>
